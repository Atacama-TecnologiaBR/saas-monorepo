# ═══════════════════════════════════════════════════════════════
#  Monorepo SaaS — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
# ═══════════════════════════════════════════════════════════════

# ─── COMPARTILHADO ─────────────────────────────────────────────
# Esta chave é usada pelo Go (LastSaaS) para ASSINAR tokens JWT
# E pelo Django (BrightBean) para VALIDAR os mesmos tokens.
# Gere com: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32_other

# ─── LASTSAAS (Go backend) ─────────────────────────────────────
MONGODB_URI=mongodb://mongodb:27017
DATABASE_NAME=lastsaas
APP_NAME=MyApp
FRONTEND_URL=http://localhost

# Email (Resend)
RESEND_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=MyApp

# Stripe (opcional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost/api/auth/github/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URL=http://localhost/api/auth/microsoft/callback

WEBHOOK_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32_other2

# ─── BRIGHTBEAN (Django backend) ───────────────────────────────
# DATABASE_URL é montado automaticamente pelo docker-compose
DJANGO_SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_50
DJANGO_DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# OAuth social (opcional)
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=

# Redes sociais (adicione conforme necessidade)
PLATFORM_PINTEREST_APP_ID=
PLATFORM_PINTEREST_APP_SECRET=
